# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Edge Function secrets (set in Supabase → Settings → Edge Functions → Secrets, NOT here)
# ALLOWED_ORIGIN=https://yourapp.vercel.app   ← restricts CORS to your domain
# ADMIN_NOTIFICATION_EMAIL=admin@yourcompany.com  ← receives invite notifications
# Service-role key — bypasses RLS. Used only in admin portal pages.
# Get from: Supabase → Settings → API → Secret key (sb_secret_...)
VITE_SUPABASE_SERVICE_KEY=sb_secret_...

# Sentry (optional — if not set, errors are only logged to the console)
# Get DSN from: sentry.io → Project Settings → Client Keys (DSN)
# VITE_SENTRY_DSN=https://xxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx

# Anthropic
# NOTE: Do NOT add an Anthropic API key here. All Claude calls are proxied
# through the call-claude Supabase edge function. The key lives in
# Supabase → Settings → Edge Functions → Secrets (ANTHROPIC_API_KEY), not here.

# Optional: override the default Claude model (default: claude-sonnet-4-6)
# VITE_CLAUDE_MODEL=claude-sonnet-4-6

# Demo mode — shows a "Load Demo Data" button in Admin → Settings
# Set to true in .env.local for demo/staging environments; never in production
# VITE_DEMO_MODE=true

# LinkedIn sourcing via Apify (token lives in Supabase Edge Function secrets, NOT here)
# APIFY_API_TOKEN=apify_api_...   ← set in Supabase → Settings → Edge Functions → Secrets

# Apify mock mode — set to true for local testing without spending Apify credits
# Returns 5 hardcoded realistic profiles so you can test the full sourcing → scoring → pipeline flow
# APIFY_MOCK=false
