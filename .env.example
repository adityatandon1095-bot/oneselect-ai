# =============================================================================
# ONE SELECT — Environment Variables Reference
# Copy this file to .env.local for local development.
# NEVER commit .env or .env.local — they are in .gitignore.
# =============================================================================

# ── Frontend variables (VITE_ prefix → bundled into the browser JS) ─────────
# These are safe to expose: the anon key is public by design.
# NEVER give the service-role key a VITE_ prefix — it would end up in the bundle.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Sentry error tracking (optional)
# VITE_SENTRY_DSN=https://xxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx

# Demo mode — shows "Load Demo Data" in Admin → Settings (dev/staging only)
# VITE_DEMO_MODE=false

# Override the default Claude model used by frontend AI calls
# VITE_CLAUDE_MODEL=claude-sonnet-4-6

# ── Supabase Edge Function secrets ───────────────────────────────────────────
# Set these in: Supabase Dashboard → Settings → Edge Functions → Secrets
# Do NOT add them here with a VITE_ prefix — they must stay server-side.
#
# ANTHROPIC_API_KEY=sk-ant-...      ← Claude API key (server-side only)
# RESEND_API_KEY=re_...             ← Resend email API key (server-side only)
# APIFY_API_TOKEN=apify_api_...     ← LinkedIn sourcing (server-side only)
# ALLOWED_ORIGIN=https://yourapp.vercel.app  ← Restrict CORS to your domain
# ADMIN_NOTIFICATION_EMAIL=admin@yourcompany.com
# APIFY_MOCK=false                  ← Set true to use mock profiles in dev

# ── WARNING: VITE_RESEND_API_KEY is WRONG naming ─────────────────────────────
# If you see VITE_RESEND_API_KEY in your .env, rename it to RESEND_API_KEY and
# move it to Supabase Edge Function secrets. The VITE_ prefix would expose it
# in the browser bundle. Edge functions read it as Deno.env.get('RESEND_API_KEY').
