# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service-role key — bypasses RLS. Used only in admin portal pages.
# Get from: Supabase → Settings → API → Secret key (sb_secret_...)
VITE_SUPABASE_SERVICE_KEY=sb_secret_...

# Anthropic
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...
# Optional: override the default Claude model (default: claude-sonnet-4-6)
# VITE_CLAUDE_MODEL=claude-sonnet-4-6
